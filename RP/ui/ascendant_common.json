	 * Borderless classic panel image used as a screen background.
	 */
	"screen": {
		"type": "image",
		"texture": "textures/ui/panels/panel_classic_borderless",
		"$size|default": [86, 158],
		"size": "$size",
		"layer": 0
	},

	/* SUBSECTION: DIALOG BACKGROUNDS
	 * Base background images for dialog panels.
	 */

	/* ELEMENT: dialog_background_dark
	 * Dark dialog background image.
	 */
	"dialog_background_dark": {
		"type": "image",
		"texture": "textures/ui/panels/background_panel_dark"
	},

	/* ELEMENT: dialog_background_blue
	 * Blue dialog background image.
	 */
	"dialog_background_blue": {
