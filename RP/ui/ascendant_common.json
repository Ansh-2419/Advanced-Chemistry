		"$has_outline|default": false,
		"$outline_color|default": "textures/ui/frozen_outline",
		"$outline_size|default": [22, 22],
		"$cell_overlay_ref|default": "common.cell_overlay",
		"$button_ref|default": "common.container_slot_button_prototype",
		"$stack_count_required|default": true,
		"$durability_bar_required|default": true,
		"$storage_bar_required|default": true,
		"$item_renderer|default": "common.item_renderer",
		"$item_renderer_panel_size|default": "$slot_panel_size",
		"$item_renderer_size|default": [16, 16],
		"$item_renderer_offset|default": [0, 0],
		"$slot_background_enabled|default": false,
		"$slot_background_ref|default": "ascendant_common.panel_bg_dark",
		"$slot_background_size|default": "$slot_panel_size",
		"$slot_background_offset|default": "$slot_panel_offset",
		"$slot_background_layer|default": -1,
		"$cell_image_ref|default": "common.cell_image_panel",
		"$cell_image_control_name|default": "cell",
		"$focus_id|default": "",
		"$focus_override_down|default": "",
		"$focus_override_up|default": "",
		"$focus_override_left|default": "",
		"$focus_override_right|default": "",
		"$slot_panel_mode|auto": {
			"$slot_panel_size": "$slot_panel_auto_size",
			"$slot_panel_offset": "$slot_panel_auto_offset",
			"$cell_image_size": "$slot_panel_auto_size",
			"$slot_background_size": "$slot_panel_auto_size",
			"$slot_background_offset": "$slot_panel_auto_offset"
		},
		"$slot_bg_variant|gray": {
			"$cell_image_ref": "common.cell_image_panel"
