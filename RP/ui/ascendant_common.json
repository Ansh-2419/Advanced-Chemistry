	/* SUBSECTION: ITEM GRIDS
	 * Reusable item grids for 2x2 and 3x3 layouts.
	 */

	/* ELEMENT: grid_2x2
	 * 2x2 slot grid with manual slot indices.
	 * SIMPLE EXAMPLE:
	 * { "grid@ascendant_common.grid_2x2": { "$slot_index_0": 0, "$slot_index_1": 1, "$slot_index_2": 2, "$slot_index_3": 3 } }
	 */
	"grid_2x2": {
		"type": "panel",
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"offset": [0, 0],
		"size": [36, 36],
		"layer": 2,
		"$slot_index_0|default": 2,
		"$slot_index_1|default": 3,
		"$slot_index_2|default": 4,
		"$slot_index_3|default": 5,
		"$slot_control|default": "ascendant_common.slot_base",
		"controls": [
			{
				"grid_2x2_slot_0@$slot_control": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [0, 0],
					"$slot_index": "$slot_index_0"
				}
			},
			{
				"grid_2x2_slot_1@$slot_control": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [18, 0],
					"$slot_index": "$slot_index_1"
				}
			},
			{
				"grid_2x2_slot_2@$slot_control": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [0, 18],
					"$slot_index": "$slot_index_2"
				}
			},
			{
				"grid_2x2_slot_3@$slot_control": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [18, 18],
					"$slot_index": "$slot_index_3"
				}
			}
		]
	},

	/* ELEMENT: grid_3x3
	 * 3x3 slot grid with manual slot indices.
	 */
	"grid_3x3": {
		"type": "panel",
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"offset": [0, 0],
		"size": [54, 54],
		"layer": 2,
		"$cell_size|default": [18, 18],
		"$size|default": [54, 54],
		"$slot_index_0|default": 2,
		"$slot_index_1|default": 3,
		"$slot_index_2|default": 4,
		"$slot_index_3|default": 5,
		"$slot_index_4|default": 6,
		"$slot_index_5|default": 7,
		"$slot_index_6|default": 8,
		"$slot_index_7|default": 9,
		"$slot_index_8|default": 10,
		"$slot_control|default": "common.container_item",
		"controls": [
			{
				"grid_3x3_slot_0@$slot_control": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [0, 0],
					"size": "$cell_size",
					"$cell_image_size": "$cell_size",
					"collection_panel": "$slot_index_0",
					"$slot_index": "$slot_index_0"
				}
			},
			{
				"grid_3x3_slot_1@$slot_control": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [18, 0],
					"size": "$cell_size",
					"$cell_image_size": "$cell_size",
					"collection_index": "$slot_index_1",
					"$slot_index": "$slot_index_1"
				}
			},
			{
				"grid_3x3_slot_2@$slot_control": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [36, 0],
					"size": "$cell_size",
					"$cell_image_size": "$cell_size",
					"collection_index": "$slot_index_2",
					"$slot_index": "$slot_index_2"
				}
			},
			{
				"grid_3x3_slot_3@$slot_control": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [0, 18],
					"size": "$cell_size",
					"$cell_image_size": "$cell_size",
					"collection_index": "$slot_index_3",
					"$slot_index": "$slot_index_3"
				}
			},
			{
				"grid_3x3_slot_4@$slot_control": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [18, 18],
					"size": "$cell_size",
					"$cell_image_size": "$cell_size",
					"collection_index": "$slot_index_4",
					"$slot_index": "$slot_index_4"
				}
			},
			{
				"grid_3x3_slot_5@$slot_control": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [36, 18],
					"size": "$cell_size",
					"$cell_image_size": "$cell_size",
					"collection_index": "$slot_index_5",
					"$slot_index": "$slot_index_5"
				}
