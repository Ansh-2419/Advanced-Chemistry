					"$toggle_property_bag": "$toggle_property_bag",
					"$radio_toggle_group": "$radio_toggle_group",
					"$toggle_group_forced_index": "$toggle_group_forced_index",
					"$toggle_group_default_selected": "$toggle_group_default_selected",
					"$allow_controller_back_button_mapping": "$allow_controller_back_button_mapping",
					"$enable_directional_toggling": "$enable_directional_toggling",
					"$toggle_on_button": "$toggle_on_button",
					"$toggle_off_button": "$toggle_off_button",
					"$toggle_tts_name": "$toggle_tts_name",
					"$toggle_tts_toggle_on_text": "$toggle_tts_toggle_on_text",
					"$toggle_tts_toggle_off_text": "$toggle_tts_toggle_off_text",
					"$toggle_tts_override_toggle_value": "$toggle_tts_override_toggle_value",
					"$toggle_tts_type_priority": "$toggle_tts_type_priority",
					"$toggle_tts_index_priority": "$toggle_tts_index_priority",
					"$toggle_tts_inherit_siblings": "$toggle_tts_inherit_siblings",
					"$tts_section_header": "$tts_section_header",
					"$unchecked_control": "$unchecked_control",
					"$checked_control": "$checked_control",
					"$unchecked_hover_control": "$unchecked_hover_control",
					"$checked_hover_control": "$checked_hover_control",
					"$unchecked_locked_control": "$unchecked_locked_control",
					"$checked_locked_control": "$checked_locked_control",
					"$unchecked_locked_hover_control": "$unchecked_locked_hover_control",
					"$checked_locked_hover_control": "$checked_locked_hover_control"
				}
			},
			{
				"toggle_label": {
					"type": "label",
					"text": "$toggle_label",
					"color": "$toggle_label_color",
					"font_scale_factor": "$toggle_label_font_scale",
					"anchor_from": "$toggle_label_anchor",
					"anchor_to": "$toggle_label_anchor",
					"offset": "$toggle_label_offset",
					"layer": 3,
					"ignored": "($toggle_label = '')"
				}
			}
		]
	},

	/* SECTION: VISUAL INDICATORS
	 * Simple visual indicators such as arrows.
	 */

	/* SUBSECTION: PROGRESS INDICATORS
	 * Progress arrows and related indicators.
	 */

	/* ELEMENT: progress_arrow
	 * Horizontal progress arrow pointing to the right.
	 */
	"progress_arrow": {
		"type": "image",
		"texture": "textures/ui/arrow_dark_right_stretch",
		"size": [22, 15],
		"layer": 1
	}
}
