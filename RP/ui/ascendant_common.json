					"$panel_alpha": "$tab_button_panel_alpha",
					"$has_container_label": false,
					"$has_close_button": false,
					"layer": 0
				}
			},
			{
				"icon": {
					"type": "image",
					"texture": "$tab_button_icon",
					"size": "$tab_button_icon_size",
					"offset": "$tab_button_icon_offset",
					"color": "$tab_button_icon_color",
					"anchor_from": "center",
					"anchor_to": "center",
					"layer": 2,
					"ignored": "($tab_button_icon = '')"
				}
			},
			{
				"label": {
					"type": "label",
					"text": "$tab_button_text",
					"font_scale_factor": "$tab_button_text_scale",
					"text_alignment": "center",
					"color": "$tab_button_text_color",
					"anchor_from": "center",
					"anchor_to": "center",
					"layer": 1
				}
			}
		]
	},

	/* ELEMENT: tab_button_state_checked
	 * Checked visual state for a tab toggle.
	 */
	"tab_button_state_checked@ascendant_common.tab_button_state_base": {
		"$tab_button_panel_color": "black",
		"$tab_button_panel_alpha": 0.95
	},

	/* ELEMENT: tab_button_state_unchecked_hover
	 * Hover visual state for an unchecked tab toggle.
	 */
	"tab_button_state_unchecked_hover@ascendant_common.tab_button_state_base": {
		"$tab_button_panel_color": "gray",
		"$tab_button_panel_alpha": 1
	},

	/* ELEMENT: tab_button_state_checked_hover
	 * Hover visual state for a checked tab toggle.
	 */
	"tab_button_state_checked_hover@ascendant_common.tab_button_state_checked": {
		"$tab_button_panel_alpha": 1
	},

	/* SUBSECTION: TAB BUTTONS
	 * Toggle controls that select the active tab.
	 */

	/* ELEMENT: tab_button_toggle
	 * Toggle-based tab button.
	 */
	"tab_button_toggle@common.toggle": {
		"size": "$tab_button_size",
		"$tab_button_size|default": [36, 20],
		"$tab_button_text|default": "Tab",
		"$tab_button_text_scale|default": 0.6,
		"$tab_button_icon|default": "",
		"$tab_button_icon_size|default": [12, 12],
		"$tab_button_icon_offset|default": [0, 0],
		"$tab_button_icon_color|default": [1, 1, 1],
		"$tab_group_name|default": "tabs_group",
		"$tab_index|default": 0,
		"$toggle_state_binding_name|default": "#toggle_state",
		"$toggle_property_bag|default": {
			"#toggle_state": false
		},
		"$active_tab_index|default": 0,
		"$unchecked_control|default": "ascendant_common.tab_button_state_base",
		"$checked_control|default": "ascendant_common.tab_button_state_checked",
		"$unchecked_hover_control|default": "ascendant_common.tab_button_state_unchecked_hover",
		"$checked_hover_control|default": "ascendant_common.tab_button_state_checked_hover",
		"$unchecked_locked_control|default": "ascendant_common.tab_button_state_base",
		"$checked_locked_control|default": "ascendant_common.tab_button_state_checked",
		"$unchecked_locked_hover_control|default": "ascendant_common.tab_button_state_unchecked_hover",
		"$checked_locked_hover_control|default": "ascendant_common.tab_button_state_checked_hover",
		"$radio_toggle_group": true,
		"$toggle_name": "$tab_group_name",
		"$toggle_group_default_selected": "$active_tab_index",
		"$toggle_group_forced_index": "$tab_index",
		"controls": [
			{
				"unchecked@$unchecked_control": {
					"$tab_button_text": "$tab_button_text",
					"$tab_button_size": "$tab_button_size",
					"$tab_button_text_scale": "$tab_button_text_scale",
					"$tab_button_icon": "$tab_button_icon",
					"$tab_button_icon_size": "$tab_button_icon_size",
					"$tab_button_icon_offset": "$tab_button_icon_offset",
					"$tab_button_icon_color": "$tab_button_icon_color"
				}
			},
			{
				"checked@$checked_control": {
					"$tab_button_text": "$tab_button_text",
					"$tab_button_size": "$tab_button_size",
					"$tab_button_text_scale": "$tab_button_text_scale",
					"$tab_button_icon": "$tab_button_icon",
					"$tab_button_icon_size": "$tab_button_icon_size",
					"$tab_button_icon_offset": "$tab_button_icon_offset",
					"$tab_button_icon_color": "$tab_button_icon_color"
				}
			},
			{
				"unchecked_hover@$unchecked_hover_control": {
					"$tab_button_text": "$tab_button_text",
					"$tab_button_size": "$tab_button_size",
					"$tab_button_text_scale": "$tab_button_text_scale",
					"$tab_button_icon": "$tab_button_icon",
					"$tab_button_icon_size": "$tab_button_icon_size",
					"$tab_button_icon_offset": "$tab_button_icon_offset",
					"$tab_button_icon_color": "$tab_button_icon_color"
				}
			},
			{
				"checked_hover@$checked_hover_control": {
					"$tab_button_text": "$tab_button_text",
					"$tab_button_size": "$tab_button_size",
					"$tab_button_text_scale": "$tab_button_text_scale",
					"$tab_button_icon": "$tab_button_icon",
					"$tab_button_icon_size": "$tab_button_icon_size",
					"$tab_button_icon_offset": "$tab_button_icon_offset",
					"$tab_button_icon_color": "$tab_button_icon_color"
				}
			}
		]
	},

	/* ELEMENT: section_button_toggle
	 * Compact tab toggle preset for vertical section lists.
	 */
	"section_button_toggle@ascendant_common.tab_button_toggle": {
		"$tab_button_size": [60, 18],
		"$tab_button_text_scale": 0.5
	},

	/* ELEMENT: tab_button_spacing
	 * Spacer between tab buttons.
	 */
	"tab_button_spacing": {
		"type": "panel",
		"$tab_button_spacing|default": [4, 0],
		"size": "$tab_button_spacing"
	},

	/* ELEMENT: tab_buttons_panel
	 * Container for the tab navigation buttons.
	 */
	"tab_buttons_panel": {
		"type": "stack_panel",
		"orientation": "$tab_buttons_orientation",
		"$tab_buttons_orientation|default": "horizontal",
		"$tab_group_name|default": "tabs_group",
		"$active_tab_index|default": 0,
		"$has_third|default": true,
		"$has_fourth|default": true,
		"$has_fifth|default": true,
		"$tab_button_size|default": [36, 20],
		"$tab_button_spacing|default": [4, 0],
		"$tab_button_0_text|default": "tab_0",
		"$tab_button_1_text|default": "tab_1",
		"$tab_button_2_text|default": "tab_2",
		"$tab_button_3_text|default": "tab_3",
		"$tab_button_4_text|default": "tab_4",
		"controls": [
			{
				"tab_button_0@ascendant_common.tab_button_toggle": {
					"$tab_group_name": "$tab_group_name",
					"$tab_index": 0,
					"$toggle_state_binding_name": "('#' + $tab_group_name + '_tab_0')",
					"$toggle_property_bag": {
						"#toggle_state": true
					},
					"$active_tab_index": "$active_tab_index",
					"$tab_button_text": "$tab_button_0_text",
					"$tab_button_size": "$tab_button_size"
				}
			},
			{
				"spacing_0@ascendant_common.tab_button_spacing": {
					"$tab_button_spacing": "$tab_button_spacing"
				}
			},
			{
				"tab_button_1@ascendant_common.tab_button_toggle": {
					"$tab_group_name": "$tab_group_name",
					"$tab_index": 1,
					"$toggle_state_binding_name": "('#' + $tab_group_name + '_tab_1')",
					"$toggle_property_bag": {
						"#toggle_state": false
					},
					"$active_tab_index": "$active_tab_index",
					"$tab_button_text": "$tab_button_1_text",
					"$tab_button_size": "$tab_button_size"
				}
			},
			{
				"spacing_1@ascendant_common.tab_button_spacing": {
					"$tab_button_spacing": "$tab_button_spacing"
				}
			},
			{
				"tab_button_2@ascendant_common.tab_button_toggle": {
					"$tab_group_name": "$tab_group_name",
					"$tab_index": 2,
					"$toggle_state_binding_name": "('#' + $tab_group_name + '_tab_2')",
					"$toggle_property_bag": {
						"#toggle_state": false
					},
					"$active_tab_index": "$active_tab_index",
					"$tab_button_text": "$tab_button_2_text",
					"$tab_button_size": "$tab_button_size",
					"ignored": "(not $has_third)"
				}
			},
			{
				"spacing_2@ascendant_common.tab_button_spacing": {
					"$tab_button_spacing": "$tab_button_spacing",
					"ignored": "(not $has_third)"
				}
			},
			{
				"tab_button_3@ascendant_common.tab_button_toggle": {
					"$tab_group_name": "$tab_group_name",
					"$tab_index": 3,
					"$toggle_state_binding_name": "('#' + $tab_group_name + '_tab_3')",
					"$toggle_property_bag": {
						"#toggle_state": false
					},
					"$active_tab_index": "$active_tab_index",
					"$tab_button_text": "$tab_button_3_text",
					"$tab_button_size": "$tab_button_size",
					"ignored": "(not $has_fourth)"
				}
			},
			{
				"spacing_3@ascendant_common.tab_button_spacing": {
					"$tab_button_spacing": "$tab_button_spacing",
					"ignored": "(not $has_fourth)"
				}
			},
			{
				"tab_button_4@ascendant_common.tab_button_toggle": {
					"$tab_group_name": "$tab_group_name",
					"$tab_index": 4,
					"$toggle_state_binding_name": "('#' + $tab_group_name + '_tab_4')",
					"$toggle_property_bag": {
						"#toggle_state": false
					},
					"$active_tab_index": "$active_tab_index",
					"$tab_button_text": "$tab_button_4_text",
					"$tab_button_size": "$tab_button_size",
					"ignored": "(not $has_fifth)"
				}
			}
		]
	},

	/* SUBSECTION: TAB CONTENT
	 * Stack panels with visibility controlled by toggle state.
	 */

	/* ELEMENT: tab_section_base
	 * Base stack panel for a tab section.
	 */
	"tab_section_base": {
		"type": "panel",
		"$tab_toggle_control_name|default": "tab_button_0",
		"$tab_group_name|default": "tabs_group",
		"$tab_content|default": "common.empty_panel",
		"$tab_enabled|default": true,
		"controls": [
			{
				"content@$tab_content": {}
			}
		],
		"bindings": [
			{
				"binding_type": "view",
				"source_control_name": "$tab_toggle_control_name",
				"source_property_name": "#toggle_state",
				"target_property_name": "#visible",
				"resolve_sibling_scope": true
			}
		],
		"ignored": "(not $tab_enabled)"
	},

	/* ELEMENT: tab_0
	 * Tab section index 0.
	 */
	"tab_0@ascendant_common.tab_section_base": {
		"$tab_toggle_control_name": "tab_button"
	},

	/* ELEMENT: tab_1
	 * Tab section index 1.
	 */
	"tab_1@ascendant_common.tab_section_base": {
		"$tab_toggle_control_name": "tab_button"
	},

	/* ELEMENT: tab_2
	 * Tab section index 2.
	 */
	"tab_2@ascendant_common.tab_section_base": {
		"$tab_toggle_control_name": "tab_button"
	},

	/* ELEMENT: tab_3
	 * Tab section index 3.
	 */
	"tab_3@ascendant_common.tab_section_base": {
		"$tab_toggle_control_name": "tab_button"
	},

	/* ELEMENT: tab_4
	 * Tab section index 4.
	 */
	"tab_4@ascendant_common.tab_section_base": {
		"$tab_toggle_control_name": "tab_button"
	},

	/* ELEMENT: tab_wrapper_base
	 * Wrapper that places a tab button and its content together.
	 */
	"tab_wrapper_base": {
		"type": "panel",
		"anchor_from": "top_left",
		"anchor_to": "top_left",
		"size": ["100%", "100%"],
		"$tab_group_name|default": "tabs_group",
		"$tab_index|default": 0,
		"$tab_button_text|default": "Tab",
		"$tab_button_size|default": [36, 20],
		"$tab_button_text_scale|default": 0.6,
		"$tab_button_offset|default": [0, 0],
		"$tab_content_offset|default": [0, 24],
		"$toggle_default_state|default": false,
		"$tab_content|default": "common.empty_panel",
		"$tab_enabled|default": true,
		"controls": [
			{
				"tab_button@ascendant_common.tab_button_toggle": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": "$tab_button_offset",
					"layer": 2,
					"toggle_default_state": "$toggle_default_state",
					"$tab_group_name": "$tab_group_name",
					"$tab_index": "$tab_index",
					"$tab_button_text": "$tab_button_text",
					"$tab_button_size": "$tab_button_size",
					"$tab_button_text_scale": "$tab_button_text_scale"
				}
			},
			{
				"tab_content@ascendant_common.tab_section_base": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": "$tab_content_offset",
					"layer": 1,
					"$tab_toggle_control_name": "tab_button",
					"$tab_content": "$tab_content"
				}
			}
		],
		"ignored": "(not $tab_enabled)"
	},

	/* ELEMENT: tabs_content_panel
	 * Container that hosts the five tab sections.
	 */
	"tabs_content_panel": {
		"type": "panel",
		"$tab_group_name|default": "tabs_group",
		"$has_third|default": true,
		"$has_fourth|default": true,
		"$has_fifth|default": true,
		"$tab_0_content|default": "common.empty_panel",
		"$tab_1_content|default": "common.empty_panel",
		"$tab_2_content|default": "common.empty_panel",
		"$tab_3_content|default": "common.empty_panel",
		"$tab_4_content|default": "common.empty_panel",
		"controls": [
			{
				"tab_0@ascendant_common.tab_0": {
					"$tab_content": "$tab_0_content",
					"$tab_group_name": "$tab_group_name"
				}
			},
			{
				"tab_1@ascendant_common.tab_1": {
					"$tab_content": "$tab_1_content",
					"$tab_group_name": "$tab_group_name"
				}
			},
			{
				"tab_2@ascendant_common.tab_2": {
					"$tab_content": "$tab_2_content",
					"$tab_enabled": "$has_third",
					"$tab_group_name": "$tab_group_name"
				}
			},
			{
				"tab_3@ascendant_common.tab_3": {
					"$tab_content": "$tab_3_content",
					"$tab_enabled": "$has_fourth",
					"$tab_group_name": "$tab_group_name"
				}
			},
			{
				"tab_4@ascendant_common.tab_4": {
					"$tab_content": "$tab_4_content",
					"$tab_enabled": "$has_fifth",
					"$tab_group_name": "$tab_group_name"
				}
			}
		]
	},

	/* SUBSECTION: TAB ROOT
	 * Assembles the buttons and content panels.
	 */

	/* ELEMENT: tabs_root
	 * Root container for the tab system.
	 */
	"tabs_root": {
		"type": "panel",
		"size": ["100%", "100%"],
		"$tab_group_name|default": "tabs_group",
		"$active_tab_index|default": 0,
		"$has_third|default": true,
		"$has_fourth|default": true,
		"$has_fifth|default": true,
		"$tabs_buttons_offset|default": [0, 0],
		"$tabs_buttons_layer|default": 1,
		"$tabs_content_offset|default": [0, 24],
		"$tabs_content_layer|default": 2,
		"$tab_buttons_orientation|default": "horizontal",
		"$tab_button_size|default": [36, 20],
		"$tab_button_spacing|default": [4, 0],
		"$tab_button_offset_0|default": [0, 0],
		"$tab_button_offset_1|default": [40, 0],
		"$tab_button_offset_2|default": [80, 0],
		"$tab_button_offset_3|default": [120, 0],
		"$tab_button_offset_4|default": [160, 0],
		"$tab_button_0_text|default": "tab_0",
		"$tab_button_1_text|default": "tab_1",
		"$tab_button_2_text|default": "tab_2",
		"$tab_button_3_text|default": "tab_3",
		"$tab_button_4_text|default": "tab_4",
		"$tab_0_content|default": "common.empty_panel",
		"$tab_1_content|default": "common.empty_panel",
		"$tab_2_content|default": "common.empty_panel",
		"$tab_3_content|default": "common.empty_panel",
		"$tab_4_content|default": "common.empty_panel",
		"controls": [
			{
				"tab_0@ascendant_common.tab_wrapper_base": {
					"$tab_group_name": "$tab_group_name",
					"$tab_index": 0,
					"$tab_button_text": "$tab_button_0_text",
					"$tab_button_size": "$tab_button_size",
					"$tab_button_offset": "$tab_button_offset_0",
					"$tab_content_offset": "$tabs_content_offset",
					"$toggle_default_state": true,
					"$tab_content": "$tab_0_content"
				}
			},
			{
				"tab_1@ascendant_common.tab_wrapper_base": {
					"$tab_group_name": "$tab_group_name",
					"$tab_index": 1,
					"$tab_button_text": "$tab_button_1_text",
					"$tab_button_size": "$tab_button_size",
					"$tab_button_offset": "$tab_button_offset_1",
					"$tab_content_offset": "$tabs_content_offset",
					"$toggle_default_state": false,
					"$tab_content": "$tab_1_content"
				}
			},
			{
				"tab_2@ascendant_common.tab_wrapper_base": {
					"$tab_group_name": "$tab_group_name",
					"$tab_index": 2,
					"$tab_button_text": "$tab_button_2_text",
					"$tab_button_size": "$tab_button_size",
					"$tab_button_offset": "$tab_button_offset_2",
					"$tab_content_offset": "$tabs_content_offset",
					"$toggle_default_state": false,
					"$tab_content": "$tab_2_content",
					"$tab_enabled": "$has_third"
				}
			},
			{
				"tab_3@ascendant_common.tab_wrapper_base": {
					"$tab_group_name": "$tab_group_name",
					"$tab_index": 3,
					"$tab_button_text": "$tab_button_3_text",
					"$tab_button_size": "$tab_button_size",
					"$tab_button_offset": "$tab_button_offset_3",
					"$tab_content_offset": "$tabs_content_offset",
					"$toggle_default_state": false,
					"$tab_content": "$tab_3_content",
					"$tab_enabled": "$has_fourth"
				}
			},
			{
				"tab_4@ascendant_common.tab_wrapper_base": {
					"$tab_group_name": "$tab_group_name",
					"$tab_index": 4,
					"$tab_button_text": "$tab_button_4_text",
					"$tab_button_size": "$tab_button_size",
					"$tab_button_offset": "$tab_button_offset_4",
					"$tab_content_offset": "$tabs_content_offset",
					"$toggle_default_state": false,
					"$tab_content": "$tab_4_content",
					"$tab_enabled": "$has_fifth"
				}
			}
		]
	},

	/* SECTION: SCROLLING
	 * Scrollable panels and scrollbars.
	 */

	/* ELEMENT: scroll_nothing_panel
	 * Empty panel used as a scroll background.
	 */
	"scroll_nothing_panel": {
		"type": "panel",
		"size": ["100%", "100%"]
	},

	/* ELEMENT: scroll_box
	 * Draggable scrollbar thumb.
	 */
	"scroll_box": {
		"type": "panel",
		"controls": [
			{
				"actual_box": {
					"type": "scrollbar_box",
					"anchor_to": "top_left",
					"anchor_from": "top_left",
					"layer": 5,
					"contained": true,
					"draggable": "vertical",
					"button_mappings": [
						{
							"from_button_id": "button.menu_select",
							"to_button_id": "button.menu_select",
							"mapping_type": "pressed",
							"button_up_right_of_first_refusal": true
						}
					],
					"controls": [
						{
							"mouse_box": {
								"type": "image",
								"texture": "textures/ui/cell_image"
							}
						}
					]
				}
			}
		]
	},

	/* ELEMENT: scrollbar_track
	 * Scrollbar track control.
	 */
	"scrollbar_track": {
		"type": "scroll_track",
		"button_mappings": [
			{
				"from_button_id": "button.menu_select",
				"to_button_id": "button.scrollbar_skip_track",
				"mapping_type": "pressed"
			}
		]
	},

	/* ELEMENT: scroll_view_control
	 * Scroll view with a vertical scrollbar.
	 */
	"scroll_view_control": {
		"$scrolling_content|default": "common.empty_panel",
		"$scrolling_background|default": "ascendant_common.scroll_nothing_panel",
		"type": "scroll_view",
		"anchor_from": "left_middle",
		"anchor_to": "left_middle",
		"size": ["100%+20px", "100%"],
		"scroll_speed": 5,
		"scrollbar_track_button": "button.scrollbar_skip_track",
		"scrollbar_touch_button": "button.scrollbar_touch",
		"always_listen_to_input": true,
		"always_handle_pointer": true,
		"scrollbar_track": "track",
		"scrollbar_box": "actual_box",
		"always_handle_scrolling": false,
		"scroll_view_port": "viewport",
		"scroll_box_and_track_panel": "bar_and_track",
		"scroll_content": "scrolling_content",
		"jump_to_bottom_on_update": false,
		"button_mappings": [
			{
				"from_button_id": "button.menu_select",
				"to_button_id": "button.scrollbar_touch",
				"mapping_type": "pressed",
				"button_up_right_of_first_refusal": true
			}
		],
		"controls": [
			{
				"viewport": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"type": "panel",
					"size": ["100%-20px", "100%+0.4px"],
					"clips_children": true,
					"layer": -4,
					"controls": [
						{
							"scrolling_content@$scrolling_content": {}
						}
					]
				}
			},
			{
				"background@$scrolling_background": {}
			},
			{
				"bar_and_track": {
					"type": "panel",
					"size": [14, "100%-2px"],
					"offset": [0, 0],
					"anchor_from": "right_middle",
					"anchor_to": "right_middle",
					"layer": 5,
					"controls": [
						{
							"track@ascendant_common.scrollbar_track": {
								"layer": 2,
								"anchor_from": "center",
								"anchor_to": "center"
							}
						},
						{
							"scroll_box@ascendant_common.scroll_box": {
								"layer": 5,
								"anchor_from": "center",
								"anchor_to": "center"
							}
						},
						{
							"outline": {
								"type": "image",
								"size": ["100%+2px", "100%+2px"],
								"texture": "textures/ui/cell_image"
							}
						},
						{
							"outline_outer": {
								"type": "image",
								"layer": -1,
								"size": ["100%+6px", "100%+8px"],
								"offset": [1, 0],
								"texture": "textures/ui/button_borderless_darkpressednohover"
							}
						}
					]
				}
			}
		]
	},

	/* ELEMENT: scrolling_panel
	 * Wrapper for a configurable scroll view.
	 */
	"scrolling_panel": {
		"type": "panel",
		"$scrolling_content|default": "common.empty_panel",
		"$scrolling_background|default": "ascendant_common.scroll_nothing_panel",
		"size": [162, 72],
		"controls": [
			{
				"scrolling_panel_base": {
					"type": "input_panel",
					"anchor_to": "top_left",
					"anchor_from": "top_left",
					"controls": [
						{
							"view_control@ascendant_common.scroll_view_control": {
								"$scrolling_content": "$scrolling_content",
								"$scrolling_background": "$scrolling_background"
							}
						}
					],
					"button_mappings": []
				}
			}
		]
	},

	/* SUBSECTION: IRON CHEST SCROLL PANELS
	 * Scroll view presets for 9x3 and 9x4 viewports.
	 */
	"scroll_panel_9x3": {
		"type": "panel",
		"$scrolling_content|default": "common.empty_panel",
		"$scrolling_background|default": "ascendant_common.scroll_nothing_panel",
		"size": [162, 54],
		"controls": [
			{
				"scrolling_panel_base": {
					"type": "input_panel",
					"anchor_to": "top_left",
					"anchor_from": "top_left",
					"controls": [
						{
							"view_control@ascendant_common.scroll_view_control": {
								"$scrolling_content": "$scrolling_content",
								"$scrolling_background": "$scrolling_background"
							}
						}
					],
					"button_mappings": []
				}
			}
		]
	},

	"scroll_panel_9x4": {
		"type": "panel",
		"$scrolling_content|default": "common.empty_panel",
		"$scrolling_background|default": "ascendant_common.scroll_nothing_panel",
		"size": [162, 72],
		"controls": [
			{
				"scrolling_panel_base": {
					"type": "input_panel",
					"anchor_to": "top_left",
					"anchor_from": "top_left",
					"controls": [
						{
							"view_control@ascendant_common.scroll_view_control": {
								"$scrolling_content": "$scrolling_content",
								"$scrolling_background": "$scrolling_background"
							}
						}
					],
					"button_mappings": []
				}
			}
		]
	},

	/* SECTION: TEXT
	 * Reusable text elements.
	 */

	/* SUBSECTION: LABELS
	 * Small labels and section headers.
	 */

	/* ELEMENT: item_label
	 * Label that always displays the item name at a specific index.
	 */
	"item_label": {
		"type": "label",
		"$item_collection_name|default": "container_items",
		"$collection_index|default": 0,
		"text": "#item_name",
		"color": [0, 1, 0],
		"layer": 1,
		"localize": false,
		"collection_index": "$collection_index",
		"bindings": [
			{
				"binding_name": "#item_name",
				"binding_type": "collection",
				"binding_collection_name": "$item_collection_name"
			}
		]
	},
	
	"item_label_view": {
		"type": "label",
		"$item_collection_name|default": "container_items",
		"$collection_index|default": 0,
		"text": "#item_name",
		"color": [0, 1, 0],
		"layer": 1,
		"localize": false,
		"$visible_source_control_name|default": "",
		"$visible_source_property_name|default": "#toggle_state",
		"$visible_target_property_name|default": "#visible",
		"font_scale_factor": 1,
		"collection_index": "$collection_index",
		"bindings": [
			{
				"binding_name": "#item_name",
				"binding_type": "collection",
				"binding_collection_name": "$item_collection_name"
			},
			{
				"binding_type": "view",
				"source_control_name": "$visible_source_control_name",
				"source_property_name": "$visible_source_property_name",
				"target_property_name": "$visible_target_property_name",
				"resolve_sibling_scope": true
			}
		]
	},

	/* ELEMENT: section_label
	 * Section label with a smaller font size.
	 */
	"section_label": {
		"type": "label",
		"$label_text|default": "Label",
		"$label_color|default": [1, 1, 1],
		"text": "$label_text",
		"font_scale_factor": 0.7,
		"color": "$label_color",
		"layer": 1
	},

	/* ELEMENT: selected_item_label
	 * Label that displays the selected item name.
	 */
	"selected_item_label": {
		"type": "label",
		"text": "#selected_hover_text",
		"color": [0, 1, 0],
		"layer": 1,
		"localize": false
	},

	/* SECTION: TOGGLES
	 * Toggle components and visual states.
	 */

	/* SUBSECTION: TOGGLE STATES
	 * Visual states for toggle controls.
	 */

	/* ELEMENT: toggle_state_unchecked
	 * Visual state for unchecked toggles.
	 */
	"toggle_state_unchecked": {
		"type": "panel",
		"size": ["100%", "100%"],
		"$toggle_state_panel_color|default": "dark",
		"$toggle_state_panel_texture|default": "",
		"$toggle_state_panel_alpha|default": 1,
		"$toggle_state_icon_size|default": [8, 8],
		"$toggle_state_icon_offset|default": [0, 0],
		"$toggle_state_icon_color|default": [1, 1, 1],
		"controls": [
			{
				"bg@ascendant_common.panel": {
					"size": ["100%", "100%"],
					"$panel_size": ["100%", "100%"],
					"$panel_color": "$toggle_state_panel_color",
					"$panel_texture": "$toggle_state_panel_texture",
					"$panel_alpha": "$toggle_state_panel_alpha",
					"$has_container_label": false,
					"$has_close_button": false,
					"layer": 0
				}
			},
			{
				"plus": {
					"type": "image",
					"texture": "textures/ui/plus",
					"size": "$toggle_state_icon_size",
					"offset": "$toggle_state_icon_offset",
					"color": "$toggle_state_icon_color",
					"anchor_from": "center",
					"anchor_to": "center",
					"layer": 1
				}
			}
		]
	},

	/* ELEMENT: toggle_state_checked
	 * Visual state for checked toggles.
	 */
	"toggle_state_checked": {
		"type": "panel",
		"size": ["100%", "100%"],
		"$toggle_state_panel_color|default": "black",
		"$toggle_state_panel_texture|default": "",
		"$toggle_state_panel_alpha|default": 0.95,
		"$toggle_state_icon_size|default": [8, 8],
		"$toggle_state_icon_offset|default": [0, 0],
		"$toggle_state_icon_color|default": [1, 1, 1],
		"controls": [
			{
				"bg@ascendant_common.panel": {
					"size": ["100%", "100%"],
					"$panel_size": ["100%", "100%"],
					"$panel_color": "$toggle_state_panel_color",
					"$panel_texture": "$toggle_state_panel_texture",
					"$panel_alpha": "$toggle_state_panel_alpha",
					"$has_container_label": false,
					"$has_close_button": false,
					"layer": 0
				}
			},
			{
				"minus": {
					"type": "image",
					"texture": "textures/ui/minus",
					"size": "$toggle_state_icon_size",
					"offset": "$toggle_state_icon_offset",
					"color": "$toggle_state_icon_color",
					"anchor_from": "center",
					"anchor_to": "center",
					"layer": 1
				}
			}
		]
	},

	/* ELEMENT: toggle_state_unchecked_hover
	 * Visual state for unchecked toggles on hover.
	 */
	"toggle_state_unchecked_hover@ascendant_common.toggle_state_unchecked": {
		"alpha": 1,
		"$toggle_state_panel_alpha": 1
	},

	/* ELEMENT: toggle_state_checked_hover
	 * Visual state for checked toggles on hover.
	 */
	"toggle_state_checked_hover@ascendant_common.toggle_state_checked": {
		"alpha": 1,
		"$toggle_state_panel_alpha": 1
	},

	/* ELEMENT: toggle_state_unchecked_locked
	 * Visual state for unchecked toggles when disabled.
	 */
	"toggle_state_unchecked_locked@ascendant_common.toggle_state_unchecked": {
		"alpha": 0.45
	},

	/* ELEMENT: toggle_state_checked_locked
	 * Visual state for checked toggles when disabled.
	 */
	"toggle_state_checked_locked@ascendant_common.toggle_state_checked": {
		"alpha": 0.45
	},

	/* SUBSECTION: TOGGLE BASE
	 * Wrapper around common.toggle with Ascendant defaults and vanilla-compatible options.
	 */

	/* ELEMENT: toggle_base
	 * Reusable toggle control exposing common.toggle features with Ascendant visual defaults.
	 */
	"toggle_base@common.toggle": {
		"$toggle_name|default": "default_toggle",
		"$toggle_default_state|default": false,
		"$toggle_binding_type|default": "global",
		"$toggle_binding_condition|default": "visible",
		"$toggle_state_binding_name|default": "#toggle_state",
		"$toggle_enabled_binding_type|default": "none",
		"$toggle_enabled_binding_condition|default": "visible",
		"$toggle_enabled_binding_name|default": "#toggle_enabled",
		"$radio_toggle_group|default": false,
		"$toggle_group_forced_index|default": -1,
		"$toggle_group_default_selected|default": 0,
		"$allow_controller_back_button_mapping|default": false,
		"$enable_directional_toggling|default": false,
		"$toggle_on_button|default": "toggle.toggle_on",
		"$toggle_off_button|default": "toggle.toggle_off",
		"$toggle_tts_name|default": "accessibility.toggle.tts.title",
		"$toggle_tts_toggle_on_text|default": "accessibility.state.on",
		"$toggle_tts_toggle_off_text|default": "accessibility.state.off",
		"$toggle_tts_override_toggle_value|default": "",
		"$toggle_tts_type_priority|default": -100,
		"$toggle_tts_index_priority|default": 150,
		"$toggle_tts_inherit_siblings|default": false,
		"$tts_section_header|default": "",
		"$toggle_property_bag|default": {
			"#toggle_state": false
		},
		"$unchecked_control|default": "ascendant_common.toggle_state_unchecked",
		"$checked_control|default": "ascendant_common.toggle_state_checked",
		"$unchecked_hover_control|default": "ascendant_common.toggle_state_unchecked_hover",
		"$checked_hover_control|default": "ascendant_common.toggle_state_checked_hover",
		"$unchecked_locked_control|default": "ascendant_common.toggle_state_unchecked_locked",
		"$checked_locked_control|default": "ascendant_common.toggle_state_checked_locked",
		"$unchecked_locked_hover_control|default": "ascendant_common.toggle_state_unchecked_locked",
		"$checked_locked_hover_control|default": "ascendant_common.toggle_state_checked_locked"
	},

	/* SUBSECTION: TOGGLE BUTTONS
	 * Toggle button base for custom UIs.
	 */

	/* ELEMENT: toggle_button_base
	 * Full toggle button with an optional icon.
	 */
	"toggle_button_base": {
		"type": "panel",
		"size": ["100%", "100%"],
		"$toggle_name|default": "default_toggle",
		"$toggle_texture|default": "",
		"$toggle_icon|default": "",
		"$toggle_label|default": "",
		"$toggle_label_color|default": [1, 1, 1],
		"$toggle_label_font_scale|default": 0.7,
		"$toggle_label_anchor|default": "center_right",
		"$toggle_label_offset|default": [8, 0],
		"$toggle_default_state|default": false,
		"$toggle_binding_type|default": "global",
		"$toggle_binding_condition|default": "visible",
		"$toggle_state_binding_name|default": "#toggle_state",
		"$toggle_enabled_binding_type|default": "none",
		"$toggle_enabled_binding_condition|default": "visible",
		"$toggle_enabled_binding_name|default": "#toggle_enabled",
		"$toggle_property_bag|default": {
			"#toggle_state": false
		},
		"$radio_toggle_group|default": false,
		"$toggle_group_forced_index|default": -1,
		"$toggle_group_default_selected|default": 0,
		"$allow_controller_back_button_mapping|default": false,
		"$enable_directional_toggling|default": false,
		"$toggle_on_button|default": "toggle.toggle_on",
		"$toggle_off_button|default": "toggle.toggle_off",
		"$toggle_tts_name|default": "accessibility.toggle.tts.title",
		"$toggle_tts_toggle_on_text|default": "accessibility.state.on",
		"$toggle_tts_toggle_off_text|default": "accessibility.state.off",
		"$toggle_tts_override_toggle_value|default": "",
		"$toggle_tts_type_priority|default": -100,
		"$toggle_tts_index_priority|default": 150,
		"$toggle_tts_inherit_siblings|default": false,
		"$tts_section_header|default": "",
		"$unchecked_control|default": "ascendant_common.toggle_state_unchecked",
		"$checked_control|default": "ascendant_common.toggle_state_checked",
		"$unchecked_hover_control|default": "ascendant_common.toggle_state_unchecked_hover",
		"$checked_hover_control|default": "ascendant_common.toggle_state_checked_hover",
		"$unchecked_locked_control|default": "ascendant_common.toggle_state_unchecked_locked",
		"$checked_locked_control|default": "ascendant_common.toggle_state_checked_locked",
		"$unchecked_locked_hover_control|default": "ascendant_common.toggle_state_unchecked_locked",
		"$checked_locked_hover_control|default": "ascendant_common.toggle_state_checked_locked",
		"controls": [
			{
				"toggle_bg@ascendant_common.panel": {
					"size": ["100%", "100%"],
					"$panel_color": "gray",
					"$panel_texture": "$toggle_texture",
					"$has_container_label": false,
					"$has_close_button": false,
					"layer": 0
				}
			},
			{
				"toggle_icon": {
					"type": "image",
					"texture": "$toggle_icon",
					"size": [16, 16],
					"anchor_from": "center",
					"anchor_to": "center",
					"layer": 1,
					"ignored": "($toggle_icon = '')"
				}
			},
			{
				"toggle@ascendant_common.toggle_base": {
					"size": ["100%", "100%"],
					"anchor_from": "center",
					"anchor_to": "center",
					"layer": 2,
					"$toggle_name": "$toggle_name",
					"$toggle_default_state": "$toggle_default_state",
					"$toggle_binding_type": "$toggle_binding_type",
					"$toggle_binding_condition": "$toggle_binding_condition",
					"$toggle_state_binding_name": "$toggle_state_binding_name",
