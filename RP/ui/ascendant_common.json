	 * Classic long panel for machine screens.
	 */
	"panel_long_classic": {
		"type": "image",
		"texture": "textures/ui/panels/long_panel_classic",
		"size": ["100%", "100%"],
		"layer": 0
	},

	/* ELEMENT: panel_with_border
	 * Highlight panel with a border.
	 */
	"panel_with_border": {
		"type": "image",
		"texture": "textures/ui/panels/background_with_border",
		"size": ["100%", "100%"],
		"layer": 0
	},

