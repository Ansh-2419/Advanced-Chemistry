		"$slot_panel_auto_size|default": ["100% - 4px", "100% - 4px"],
		"$slot_panel_auto_offset|default": [2, 2],
		"$cell_image_size|default": "$slot_panel_size",
		"$slot_bg_variant|default": "gray",
		"$slot_color|default": "gray",
		"$slot_surface|default": "cell",
		"$slot_panel_texture|default": "",
		"$slot_panel_alpha|default": 1,
		"$slot_panel_layer|default": 0,
		"$cell_color|default": [1, 1, 1],
		"$cell_texture|default": "textures/ui/cell_image",
		"$cell_custom_enabled|default": false,
		"$outline_variant|default": "none",
