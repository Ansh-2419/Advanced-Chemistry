		},
		"$background_color|aqua": {
			"$panel_bg_control": "ascendant_common.panel_bg_aqua"
		},
		"$background_color|gray": {
			"$panel_bg_control": "ascendant_common.panel_bg"
		},
		"$background_color|white": {
			"$panel_bg_control": "ascendant_common.panel_bg_white"
		},
		"$background_color|light_gray": {
			"$panel_bg_control": "ascendant_common.panel_bg_light_gray"
		},
		"$background_color|black": {
			"$panel_bg_control": "ascendant_common.panel_bg_black"
		},
		"$background_color|brown": {
			"$panel_bg_control": "ascendant_common.panel_bg_brown"
		},
		"$background_color|red": {
			"$panel_bg_control": "ascendant_common.panel_bg_red"
		},
