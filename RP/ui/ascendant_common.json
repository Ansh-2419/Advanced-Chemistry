		"$slot_bg_variant|blue": {
			"$cell_image_ref": "ascendant_common.blue_bg"
		},
		"$slot_bg_variant|aqua": {
			"$cell_image_ref": "ascendant_common.aqua_bg"
		},
		"$slot_color|dark": {
			"$cell_image_ref": "ascendant_common.dark_cell_image_panel"
